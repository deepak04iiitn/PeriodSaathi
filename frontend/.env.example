# Telegram bot deep-link (shown in Navbar, Hero, CTASection, and Footer)
# Replace with your actual bot username once deployed
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/your_bot_username

# Canonical site URL — used for Open Graph meta tags
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Backend API base URL — used by the "joined women" counter on the landing page
NEXT_PUBLIC_API_URL=http://localhost:3000
