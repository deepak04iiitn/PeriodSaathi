# Environment Variables — PeriodSaathi

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/periodsaathi

# Express server port
PORT=3000

# Leave empty for polling mode (local dev).
# Set to your public HTTPS URL to enable webhook mode (e.g. https://yourdomain.com).
WEBHOOK_URL=

# Set to "true" to expose POST /admin/trigger-reminders for manual job testing.
ENABLE_ADMIN_ROUTES=false
