# Environment Variables — PeriodSaathi

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/periodsaathi

# Express server port
PORT=3000

# "development" uses polling; "production" uses webhooks
NODE_ENV=development

# Public URL of your server — required only in production for webhook registration
WEBHOOK_URL=https://yourdomain.com
